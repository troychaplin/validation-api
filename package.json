{
	"name": "validation-api",
	"version": "3.0.1",
	"description": "A framework for registering block, meta, and editor validation checks in the WordPress block editor",
	"author": "Troy Chaplin",
	"license": "GPL-2.0-or-later",
	"main": "build/validation-api.js",
	"sideEffects": [
		"src/index.js",
		"src/hooks/**",
		"src/store/index.js",
		"src/**/*.scss"
	],
	"packageManager": "pnpm@10.33.0",
	"lint-staged": {
		"*.{css,scss}": [
			"stylelint --fix"
		],
		"*.js": [
			"wp-scripts format",
			"wp-scripts lint-js"
		],
		"*.php": [
			"composer run format"
		]
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"core-js",
			"core-js-pure",
			"unrs-resolver"
		]
	},
	"files": [
		"[^.]*"
	],
	"scripts": {
		"build": "wp-scripts build",
		"start": "wp-scripts start",
		"test": "wp-scripts test-unit-js",
		"test:watch": "wp-scripts test-unit-js --watch",
		"format": "pnpm format:js && pnpm format:php && pnpm format:css",
		"format:js": "wp-scripts lint-js --fix",
		"format:php": "composer run format",
		"format:css": "stylelint \"**/*.scss\" --fix",
		"lint": "pnpm lint:js && pnpm lint:php && pnpm lint:css",
		"lint:js": "wp-scripts lint-js",
		"lint:php": "composer run lint",
		"lint:css": "stylelint \"**/*.scss\"",
		"clean": "rm -rf node_modules ; rm pnpm-lock.yaml ; pnpm install ; pnpm build",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"prepare": "husky"
	},
	"devDependencies": {
		"@wordpress/data": "10.44.0",
		"lint-staged": "^16.4.0",
		"@wordpress/element": "6.44.0",
		"@wordpress/env": "11.4.0",
		"@wordpress/eslint-plugin": "25.0.0",
		"@wordpress/i18n": "6.17.0",
		"@wordpress/plugins": "7.44.0",
		"@wordpress/prettier-config": "4.44.0",
		"@wordpress/scripts": "32.0.0",
		"@wordpress/stylelint-config": "23.36.0",
		"eslint-config-prettier": "10.1.8",
		"husky": "9.1.7",
		"stylelint": "17.9.1",
		"stylelint-scss": "7.0.0"
	},
	"dependencies": {
		"@wordpress/api-fetch": "^7.44.0",
		"@wordpress/components": "^32.6.0",
		"@wordpress/icons": "^12.2.0"
	}
}
