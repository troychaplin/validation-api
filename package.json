{
	"name": "validation-api",
	"version": "3.0.1",
	"description": "A framework for registering block, meta, and editor validation checks in the WordPress block editor",
	"author": "Troy Chaplin",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"packageManager": "pnpm@10.33.0",
	"lint-staged": {
		"*.{css,scss}": [
			"stylelint --fix"
		],
		"*.js": [
			"wp-scripts format",
			"wp-scripts lint-js"
		],
		"*.php": [
			"composer run format"
		]
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"core-js",
			"core-js-pure",
			"unrs-resolver"
		]
	},
	"files": [
		"[^.]*"
	],
	"scripts": {
		"build": "wp-scripts build",
		"start": "wp-scripts start",
		"format": "pnpm format:js && pnpm format:php && pnpm format:css",
		"format:js": "wp-scripts lint-js --fix",
		"format:php": "composer run format",
		"format:css": "stylelint \"**/*.scss\" --fix",
		"lint": "pnpm lint:js && pnpm lint:php && pnpm lint:css",
		"lint:js": "wp-scripts lint-js",
		"lint:php": "composer run lint",
		"lint:css": "stylelint \"**/*.scss\"",
		"clean": "rm -rf node_modules ; rm pnpm-lock.yaml ; pnpm install ; pnpm build",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"prepare": "husky"
	},
	"devDependencies": {
		"@wordpress/data": "10.35.0",
		"lint-staged": "^15.5.1",
		"@wordpress/element": "6.35.0",
		"@wordpress/env": "10.35.0",
		"@wordpress/eslint-plugin": "22.21.0",
		"@wordpress/i18n": "6.8.0",
		"@wordpress/plugins": "7.35.0",
		"@wordpress/prettier-config": "4.35.0",
		"@wordpress/scripts": "31.0.0",
		"@wordpress/stylelint-config": "23.27.0",
		"eslint-config-prettier": "10.1.8",
		"husky": "9.1.7",
		"stylelint": "16.26.0",
		"stylelint-scss": "6.12.1"
	},
	"dependencies": {
		"@wordpress/api-fetch": "^7.8.0",
		"@wordpress/components": "^28.8.0",
		"@wordpress/icons": "^11.3.0"
	}
}
